{
  "name": "petlink",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clean": "npm run kill:8081 && expo start -c",
    "kill:8081": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-NetTCPConnection -LocalPort 8081 -State Listen -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }\"",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@nozbe/watermelondb": "^0.25.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.8",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/stack": "^7.8.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.13.6",
    "expo": "^55.0.9",
    "expo-blur": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-biometrics": "^3.0.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keychain": "^10.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
