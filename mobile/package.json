{
  "name": "petlink",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go",
    "start:clean": "npm run kill:8081 && expo start -c",
    "kill:8081": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-NetTCPConnection -LocalPort 8081 -State Listen -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }\"",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.8",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/stack": "^7.8.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "expo": "~55.0.24",
    "expo-blur": "~55.0.14",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.20",
    "expo-font": "~55.0.7",
    "expo-image": "~55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.14",
    "expo-location": "~55.1.10",
    "expo-media-library": "~55.0.17",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-biometrics": "^3.0.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keychain": "^10.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-biometrics",
          "@nozbe/watermelondb"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
